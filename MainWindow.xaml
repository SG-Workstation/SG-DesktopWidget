<Window x:Class="DesktopWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面小挂件"
        Width="300" Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- 自定义菜单项样式 -->
        <Style x:Key="CustomMenuItemStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="Transparent" 
                                CornerRadius="5"
                                Padding="10,8"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="Left" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Border x:Name="BackgroundBorder"
                Background="#AA222222" 
                CornerRadius="16" 
                Padding="20" 
                BorderThickness="1" 
                BorderBrush="#55FFFFFF">
            <Grid>
                <!-- 内容区域（不透明） -->
                <Grid x:Name="ContentGrid" Opacity="1">
                    <StackPanel>
                        <TextBlock x:Name="CountdownText"
                                   FontSize="14"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,0"/>
                        <!-- 这里可以添加你的挂件内容 -->
                    </StackPanel>
                    <!-- 左下头像 -->
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,0">
                    <TextBlock x:Name="LeftAvatarNameText"
                               Text="XX"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>
                    <Image x:Name="LeftAvatarImage"
                           Source="https://lxstu.sgstudio2025.xyz/1.png"
                           Width="40"
                           Height="40"
                           Stretch="Uniform"
                           HorizontalAlignment="Left"/>
                </StackPanel>
                <!-- 右下头像 -->
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,0">
                    <TextBlock x:Name="RightAvatarNameText"
                               Text="XX"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>
                    <Image x:Name="RightAvatarImage"
                           Source="https://lxstu.sgstudio2025.xyz/2.png"
                           Width="40"
                           Height="40"
                           Stretch="Uniform"
                           HorizontalAlignment="Right"/>
                </StackPanel>
                    <!-- 中间爱心图片 -->
                <Image x:Name="CenterHeartImage"
                       Source="https://lxstu.sgstudio2025.xyz/3.png"
                       Width="48"
                       Height="48"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,8"/>
                </Grid>
            </Grid>
        </Border>
        
        <!-- 自定义右键菜单 -->
        <Popup x:Name="CustomContextMenu" 
               Placement="MousePoint"
               StaysOpen="True"
               AllowsTransparency="True">
            <Border Background="#AA222222" 
                    CornerRadius="8" 
                    BorderThickness="1" 
                    BorderBrush="#55FFFFFF"
                    Padding="5"
                    MinWidth="120">
                <StackPanel>
                    <Button x:Name="PinMenuItem"
                            Content="取消固定"
                            Style="{StaticResource CustomMenuItemStyle}"
                            Click="PinMenuItem_Click"/>
                    <Rectangle Height="1" 
                             Margin="5,2" 
                             Fill="#55FFFFFF"/>
                    <Button x:Name="SettingsMenuItem"
                            Content="设置"
                            Style="{StaticResource CustomMenuItemStyle}"
                            Click="SettingsMenuItem_Click"/>
                    <Rectangle Height="1" 
                             Margin="5,2" 
                             Fill="#55FFFFFF"/>
                    <Button x:Name="CloseMenuMenuItem"
                            Content="关闭菜单"
                            Style="{StaticResource CustomMenuItemStyle}"
                            Click="CloseMenuMenuItem_Click"/>
                    <Rectangle Height="1" 
                             Margin="5,2" 
                             Fill="#55FFFFFF"/>
                    <Button x:Name="CloseMenuItem"
                            Content="关闭程序"
                            Style="{StaticResource CustomMenuItemStyle}"
                            Click="CloseMenuItem_Click"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>